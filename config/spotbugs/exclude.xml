<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
    xmlns="https://github.com/spotbugs/spotbugs"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/spotbugs https://raw.githubusercontent.com/spotbugs/spotbugs/4.10/spotbugs/etc/findbugsfilter.xsd">

    <!-- Records expose their components by design — expected behavior -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Or>
            <Class name="com.sanmoo.eventsourcing.creditaccount.application.port.EventEnvelope"/>
            <Class name="com.sanmoo.eventsourcing.creditaccount.application.result.CommandResult"/>
            <Class name="com.sanmoo.eventsourcing.creditaccount.application.result.CreditAccountResult"/>
            <Class name="com.sanmoo.eventsourcing.creditaccount.domain.model.CreditAccountSnapshot"/>
        </Or>
    </Match>

    <!-- Spring beans store injected dependencies without defensive copy — standard practice -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Or>
            <Class name="com.sanmoo.eventsourcing.creditaccount.adapter.out.postgres.EventTypeMapper"/>
            <Class name="com.sanmoo.eventsourcing.creditaccount.adapter.out.postgres.JdbcEventStoreAdapter"/>
            <Class name="com.sanmoo.eventsourcing.creditaccount.adapter.out.postgres.JdbcIdempotencyAdapter"/>
            <Class name="com.sanmoo.eventsourcing.creditaccount.application.port.EventEnvelope"/>
            <Class name="com.sanmoo.eventsourcing.creditaccount.application.result.CommandResult"/>
            <Class name="com.sanmoo.eventsourcing.creditaccount.application.result.CreditAccountResult"/>
            <Class name="com.sanmoo.eventsourcing.creditaccount.domain.model.CreditAccountSnapshot"/>
        </Or>
    </Match>

    <!-- Service returns Map-based response data — intentional design -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="com.sanmoo.eventsourcing.creditaccount.application.service.CreditAccountCommandService"/>
    </Match>

    <!-- Spring Boot main application class is intentionally ignored -->
    <Match>
        <Bug pattern="DM_EXIT"/>
        <Class name="com.sanmoo.eventsourcing.creditaccount.CreditAccountApplication"/>
    </Match>
</FindBugsFilter>
